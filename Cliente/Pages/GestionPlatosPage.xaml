<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cliente.Pages.GestionPlatosPage"
             Title="Gestion de platos">
    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,5,0,5" />
        </Style>
    </ContentPage.Resources>
    <Grid RowDefinitions="*,Auto" ColumnDefinitions="*,*,*" ColumnSpacing="5">
        <TableView Intent="Data" Grid.Row="0" Grid.ColumnSpan="3">
            <TableRoot>
                <TableSection Title="Acciones a realizar">
                    <EntryCell Text="{Binding Path=plato.Nombre}" Placeholder="Introduzca el plato" />
                </TableSection>
            </TableRoot>
        </TableView>
        <Button Grid.Row="1" Grid.Column="0" Text="Guardar" Clicked="OnGuardarClic" Margin="20,5"/>
        <Button Grid.Row="1" Grid.Column="1" Text="Cancelar" Clicked="OnCancelarClic" Margin="0,5"/>
        <Button Grid.Row="1" Grid.Column="2" Text="Eliminar" Clicked="OnEliminarClic" Margin="20,5"/>
    </Grid>
</ContentPage>